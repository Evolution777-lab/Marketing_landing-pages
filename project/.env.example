# --- Yandex IMAP ---
# Логин почты (например, name@yandex.ru)
IMAP_USERNAME=name@yandex.ru
# ПАРОЛЬ ПРИЛОЖЕНИЯ Яндекс (не основной пароль аккаунта!)
# https://yandex.ru/support/id/authorization/app-passwords.html
IMAP_PASSWORD=your-yandex-app-password

# --- OpenAI (GPT-5.5) ---
# Если не задан — анализатор работает в режиме keyword-фолбэка
OPENAI_API_KEY=sk-your-openai-key

# Эти настройки также можно задать через UI («Настройки»).
# Значения из UI имеют приоритет над переменными окружения.
